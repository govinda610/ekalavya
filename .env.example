# Ekalavya — provider credentials. Copy to `.env` and fill in. NEVER commit `.env`.
# Both GLM and MiniMax expose Anthropic-compatible endpoints, so the app talks
# to them with one client, just different base URLs + tokens.

# GLM (z.ai coding plan) — default model: glm-5.2
EKLAVYA_GLM_API_KEY=

# MiniMax (token plan) — default model: MiniMax-M3
EKLAVYA_MINIMAX_API_KEY=

# Optional: override the default provider/model the tutor teaches with.
# EKLAVYA_PROVIDER=glm
# EKLAVYA_MODEL=glm-5.2
